# =============================================================================
# .streamlit/secrets.toml  —  SAMPLE / TEMPLATE
# -----------------------------------------------------------------------------
# Copy to .streamlit/secrets.toml and fill in. NEVER commit the real file.
# On Streamlit Cloud, paste this into App → Settings → Secrets instead.
# =============================================================================

# The app uses a local SQLite file by default (no config needed) — but that
# does NOT persist on Streamlit Cloud (its disk is wiped on restart). For the
# deployed app, point it at a persistent Postgres database such as Supabase.
#
# Supabase: create a project → Project Settings → Database → Connection string
# (URI). Use the "Connection pooling" URI for Streamlit. It looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Then set it here:

[database]
url = "postgresql://USER:PASSWORD@HOST:PORT/DBNAME"

# Local development needs no secrets at all — delete this file and the app
# falls back to sqlite:///badminton.db automatically.
