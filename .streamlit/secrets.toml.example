# =============================================================================
# .streamlit/secrets.toml  —  SAMPLE / TEMPLATE
# -----------------------------------------------------------------------------
# Copy this file and fill in your real values. NEVER commit the populated
# version to git (see .gitignore). On Streamlit Community Cloud, paste these
# same sections into  App → Settings → Secrets  instead of using this file.
# =============================================================================


# -----------------------------------------------------------------------------
# 1) Google Sheets connection  (used by st.connection("gsheets", ...))
# -----------------------------------------------------------------------------
# `spreadsheet` is the full URL (or the key) of your Google Sheet.
# The `[connections.gsheets]` block below holds the Service Account JSON
# credentials. To get these:
#   1. Google Cloud Console → create a project → enable "Google Sheets API"
#      and "Google Drive API".
#   2. Create a Service Account → create a JSON key → download it.
#   3. Copy each field from that JSON into the keys below.
#   4. Share your Google Sheet with the service account's `client_email`
#      (give it Editor access) so it can read AND write.
# -----------------------------------------------------------------------------
[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/107Mg-jGnW6LMUvWeQRd-eoptlnjS1EFYreYsLrEX2gY/edit"
worksheet = "ผู้เล่น"           # default worksheet (per-call overrides in app.py)

type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Keep the literal \n escape sequences exactly as they appear in the JSON file.
private_key = "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqh...your...key...here...\n-----END PRIVATE KEY-----\n"
client_email = "badminton-bot@your-gcp-project-id.iam.gserviceaccount.com"
client_id = "1234567890123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/badminton-bot%40your-gcp-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"

# -----------------------------------------------------------------------------
# Note: slip reading uses local OCR (Tesseract) and needs NO secrets/API keys.
# The Tesseract binary is installed from packages.txt on Streamlit Cloud.
# There are no other secrets — the app only needs the Google connection above.
# -----------------------------------------------------------------------------
